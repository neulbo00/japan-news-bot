# ============================================
# Japan News Bot - 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 이름 바꾼 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================

# [필수] Google Gemini API 키
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# ────────────────────────────────────────────
# [필수] Google Blogger 설정
# ────────────────────────────────────────────

# 블로그 ID: Blogger 관리 페이지 URL에서 확인
# https://www.blogger.com/blog/posts/{여기가 블로그ID}
BLOGGER_BLOG_ID=1234567890123456789

# OAuth2 클라이언트 정보 (Google Cloud Console에서 발급)
# https://console.cloud.google.com/apis/credentials
# → OAuth 2.0 클라이언트 ID 생성 (웹 애플리케이션)
# → 승인된 리디렉션 URI에 http://localhost:8080 추가
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# setup_google_auth.py 실행 후 자동 발급되는 리프레시 토큰
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ────────────────────────────────────────────
# [필수] 텔레그램 알림
# ────────────────────────────────────────────

# @BotFather 에게 /newbot 명령으로 발급
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# @userinfobot 에서 확인 가능
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
