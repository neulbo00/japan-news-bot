# =============================================
# Japan News Bot - 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 이름 바꾼 후 실제 값을 입력하세요.
# cp .env.example .env
# =============================================

# [필수] Google Gemini API 키
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# [필수] 티스토리 Access Token
# https://www.tistory.com/guide/api/manage/register 에서 앱 등록 후 발급
TISTORY_ACCESS_TOKEN=your_tistory_access_token_here

# [필수] 티스토리 블로그 이름 (xxx.tistory.com 에서 xxx 부분)
TISTORY_BLOG_NAME=your_blog_name

# [필수] 텔레그램 봇 토큰
# @BotFather 에게 /newbot 명령으로 발급
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# [필수] 텔레그램 채팅 ID
# @userinfobot 에서 확인 가능
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# [선택] Naver Papago API (translate.py 테스트용, 미사용)
NAVER_API_KEY_ID=your_naver_api_key_id
NAVER_API_KEY=your_naver_api_key
